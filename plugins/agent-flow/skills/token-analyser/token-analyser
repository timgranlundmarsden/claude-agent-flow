token-analyser CLI — wraps parse-logs.py and renders formatted Markdown output.

Usage:
  token-analyser [--today|--24h|--week|--session UUID]
                 [--project-path PATH]
                 [--report [OUTPUT_PATH]]
                 [--write-guidelines]
                 [--json]
"""

import argparse
import json
import os
import subprocess
import sys
from datetime import datetime
from pathlib import Path

_SKILL_DIR = Path(__file__).parent
_PARSE_LOGS = _SKILL_DIR / "parse-logs.py"

# ──────────────────────────────────────────────────────────────────────────────
# Formatting helpers
# ──────────────────────────────────────────────────────────────────────────────

def fmt_tokens(n: int) -> str:
    """Format token count: 123, 123k, 1.1M"""
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n // 1_000}k"
    return str(n)


def fmt_cost(v: float) -> str:
    return f"{v:.2f}"


def health_icon(health: str) -> str:
    return {"critical": "🔴 CRITICAL", "warning": "⚠️ WARNING", "ok": "✅ OK"}.get(health, health)


def session_health_icon(session_id_8: str, top_issues: list) -> str:
    for issue in top_issues:
        if issue.get("session", "").startswith(session_id_8[:8]):
            return "🔴"
    return "✅"


def bar(cost: float, max_cost: float, width: int = 20) -> str:
    if max_cost <= 0:
        return ""
    filled = round((cost / max_cost) * width)
    return "█" * filled


def short_model(model_id: str) -> str:
    """Convert internal model ID to short display name."""
    mapping = {
        "anthropic_claude_sonnet_4_6": "claude-sonnet-4-6",
        "anthropic_claude_opus_4_6": "claude-opus-4-6",
        "anthropic_claude_haiku_4_5": "claude-haiku-4-5",
        "anthropic_claude_haiku_4_5_20251001": "claude-haiku-4-5",
        "anthropic_claude_sonnet_4_5": "claude-sonnet-4-5",
        "claude-sonnet-4-6": "claude-sonnet-4-6",
        "claude-opus-4-6": "claude-opus-4-6",
        "claude-haiku-4-5": "claude-haiku-4-5",
    }
    return mapping.get(model_id, model_id.split("_")[-1] if "_" in model_id else model_id)


def truncate_reason(reason: str, maxlen: int = 35) -> str:
    """Take text before first em-dash, truncate to maxlen."""
    # Split on em-dash (—) or " - "
    for sep in [" — ", " - ", "—"]:
        if sep in reason:
            reason = reason.split(sep)[0].strip()
            break
    return reason[:maxlen] if len(reason) > maxlen else reason


# ──────────────────────────────────────────────────────────────────────────────
# Narrative + issues
# ──────────────────────────────────────────────────────────────────────────────

def generate_narrative(session: dict) -> str:
    ratio = session.get("ratio", 0)
    calls = session.get("api_calls", 0)
    sa_calls = session.get("subagent_calls", 0)
    duration = session.get("duration_min", 0)
    cost = session.get("est_cost_usd", 0.0)

    if sa_calls >= 20 and ratio >= 30:
        pattern = "subagent runaway"
        detail = (
            f"A subagent made {sa_calls} calls, multiplying cost. "
            "Constraining subagents to a single read + write would have cut this sharply."
        )
    elif ratio >= 50 and calls >= 20:
        pattern = "context ballooning across many tool calls"
        detail = (
            f"Claude re-read a large accumulated context on every one of the {calls} calls. "
            "Starting a fresh session per sub-task would cut this by ~80%."
        )
    elif duration <= 5 and cost >= 0.5:
        pattern = "large pre-loaded context"
        detail = "Most cost came from a large context loaded upfront, not work done in the session."
    else:
        pattern = "context accumulation"
        detail = "Cost accumulated gradually across multiple tool calls."

    id8 = session.get("id", "?")[:8]
    total_calls = calls + sa_calls
    return (
        f"> **Worst session: {id8}** "
        f"({fmt_cost(cost)} · {total_calls} calls · {ratio}:1 ratio)\n"
        f"> {pattern.capitalize()}: {detail} "
        f"You sent {ratio} tokens for every 1 token of output."
    )


_ISSUE_DESC = {
