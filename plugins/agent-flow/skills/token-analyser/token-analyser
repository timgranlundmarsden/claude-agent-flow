_MARKER = "<!-- token-analyser-guidelines -->"


def format_issues_section(top_issues: list) -> str:
    if not top_issues:
        return ""
    # Count per type
    counts: dict[str, int] = {}
    for issue in top_issues:
        t = issue.get("type", "unknown")
        counts[t] = counts.get(t, 0) + 1

    lines = ["**ISSUES FOUND**", ""]
    for t, n in counts.items():
        tmpl = _ISSUE_DESC.get(t, f"**{t}** ({n} session(s))")
        lines.append(tmpl.format(n=n))
        lines.append("")
    return "\n".join(lines)


def write_guidelines(project_path: str, issue_types: list[str]) -> str:
    """Append applicable guidelines to <project_path>/CLAUDE.md. Returns status message."""
    if not issue_types:
        return "No issues requiring guidelines."

    claude_md = Path(project_path) / "CLAUDE.md"
    existing = claude_md.read_text() if claude_md.exists() else ""

    if _MARKER in existing:
        return f"Guidelines already present in {claude_md} (marker found — skipping)."

    applicable = [t for t in issue_types if t in _GUIDELINES]
    if not applicable:
        return "No guideline templates for the detected issue types."

    sections = "\n\n".join(_GUIDELINES[t].strip() for t in applicable)
    block = f"\n\n{_MARKER}\n\n{sections}\n"

    with open(claude_md, "a") as f:
        f.write(block)

    return f"Guidelines written to {claude_md} ({', '.join(applicable)})."


# ──────────────────────────────────────────────────────────────────────────────
# Per-call breakdown
# ──────────────────────────────────────────────────────────────────────────────

def render_call_breakdown(per_call: list[dict]) -> str:
    if not per_call:
        return ""

    # Find the call with the largest cache_write spike for annotation
    max_cw_idx = max(range(len(per_call)), key=lambda i: per_call[i].get("cache_write", 0))
    max_cw = per_call[max_cw_idx].get("cache_write", 0)

    lines = [
        "**CALL BREAKDOWN**",
        "",
        "| # | Raw in | Cache write | Cache read | Context | Output | Note |",
        "|---|--------|-------------|------------|---------|--------|------|",
    ]
    for i, c in enumerate(per_call, 1):
        raw_in    = fmt_tokens(c.get("input", 0))
        cw        = fmt_tokens(c.get("cache_write", 0))
        cr        = fmt_tokens(c.get("cache_read", 0))
        ctx       = fmt_tokens(c.get("context_size", 0))
        out       = fmt_tokens(c.get("output", 0))
        note = ""
        if i - 1 == max_cw_idx and max_cw > 1000:
            note = "← largest cache write"
        lines.append(f"| {i} | {raw_in} | {cw} | {cr} | {ctx} | {out} | {note} |")
    lines.append("")
    return "\n".join(lines)


# ──────────────────────────────────────────────────────────────────────────────
# Per-model breakdown
# ──────────────────────────────────────────────────────────────────────────────

def render_model_breakdown(session: dict) -> str:
    """Render a MODEL BREAKDOWN table showing per-model call counts, tokens, cost.
    Includes a note on whether agent `model:` overrides are being respected."""
    model_stats = session.get("model_stats", {})
    if not model_stats:
        return "_No model stats available._\n"

    primary = session.get("model", "")
    total_cost = session.get("est_cost_usd", 0.0)

    # Compute cost per model
    rows = []
    for m, ms in sorted(model_stats.items(), key=lambda x: x[1]["calls"], reverse=True):
        cost = calc_cost_for_model(m, ms["input"], ms["output"], ms["cache_read"], ms["cache_write"])
        pct = round(cost / total_cost * 100) if total_cost > 0 else 0
        rows.append({
            "model": short_model(m),
            "calls": ms["calls"],
            "input": ms["input"] + ms["cache_write"],
            "output": ms["output"],
            "cost": cost,
            "pct": pct,
        })

    lines = [
        "**MODEL BREAKDOWN**",
        "",
        "| Model | Calls | Tokens in | Tokens out | Cost | % of total |",
        "|---|---|---|---|---|---|",
    ]
    for r in rows:
        lines.append(
            f"| {r['model']} | {r['calls']} | {fmt_tokens(r['input'])} "
            f"| {fmt_tokens(r['output'])} | {fmt_cost(r['cost'])} | {r['pct']}% |"
        )
    lines.append("")

    # Agent override status note
    distinct_models = set(model_stats.keys())
    if len(distinct_models) == 1:
        lines.append(
            f"> ⚠️ **All calls used a single model ({short_model(next(iter(distinct_models)))}).** "
            f"Agent definition `model:` overrides are **not** being applied — "
            f"subagents inherit the parent session model regardless of their frontmatter."
        )
    else:
        model_list = ", ".join(short_model(m) for m in sorted(distinct_models))
        lines.append(
            f"> ✅ **Multiple models detected ({model_list}).** "
            f"Agent `model:` overrides appear to be working."
        )
    lines.append("")
    return "\n".join(lines)


def calc_cost_for_model(model_id: str, input_tok: int, output_tok: int,
                        cache_read: int, cache_write: int) -> float:
    """Thin wrapper used by render_model_breakdown (parse-logs not importable here)."""
    from importlib.util import spec_from_file_location, module_from_spec
    # Reuse calc_cost from parse-logs by delegating through the already-parsed JSON
    # We just need pricing — replicate the calc_cost formula here for simplicity.
    _pricing_file = _SKILL_DIR / "reference" / "model-pricing.json"
    try:
        with open(_pricing_file) as f:
            pricing_data = json.load(f)
        pricing = pricing_data["models"]
        p = pricing.get(model_id) or pricing.get("anthropic_claude_sonnet_4_6")
        rate_in = p["in"] / 1_000_000
        rate_out = p["out"] / 1_000_000
        rate_cr = (p.get("cache_read") or 0) / 1_000_000
        rate_cw = (p.get("cache_write") or p["in"]) / 1_000_000
        return (input_tok * rate_in + output_tok * rate_out
                + cache_read * rate_cr + cache_write * rate_cw)
    except Exception:
        return 0.0


# ──────────────────────────────────────────────────────────────────────────────
# Single-session dashboard
# ──────────────────────────────────────────────────────────────────────────────

def render_single_session(data: dict, breakdown: bool = False, models: bool = False) -> str:
    sessions = data.get("sessions", [])
    session = sessions[0] if sessions else {}
    mode_label = "Current Session"
    period = data.get("period", "")
    health = data.get("health", "ok")
    issues = data.get("top_issues", [])
    savings = data.get("savings_comparison", [])

    lines = []
    lines.append(f"**TOKEN ANALYSIS** · {mode_label} · {period}")
    lines.append("")

    if not session:
        lines.append("_No session data found._")
        return "\n".join(lines)

    model = short_model(session.get("model", ""))
    api_calls = session.get("api_calls", 0)
    sa_calls = session.get("subagent_calls", 0)
    calls_str = f"{api_calls} main + {sa_calls} subagent" if sa_calls else str(api_calls)
    duration = session.get("duration_min", 0)
    input_tok = fmt_tokens(session.get("input_tokens", 0))
    output_tok = fmt_tokens(session.get("output_tokens", 0))
    cache_tok = fmt_tokens(session.get("cache_read_tokens", 0))
    cost = fmt_cost(session.get("est_cost_usd", 0.0))

    lines += [
        "| | |",
        "|---|---|",
        f"| Model | {model} |",
        f"| Health | {health_icon(health)} |",
        f"| API Calls | {calls_str} |",
        f"| Duration | {duration}m |",
        f"| Input | {input_tok} · Output {output_tok} · Cache reads {cache_tok} |",
        f"| Est. cost | **{cost}** |",
        "",
    ]

    # Cost breakdown
    cost_blocks = session.get("cost_blocks", [])
    if cost_blocks:
        max_cost = max(b.get("cost", 0) for b in cost_blocks) or 1
        lines += [
            "**COST BREAKDOWN**",
            "",
            "| Calls | Tokens in | Cost | Bar |",
            "|---|---|---|---|",
        ]
        for b in sorted(cost_blocks, key=lambda x: x.get("cost", 0), reverse=True):
            label = b.get("label", "")
            calls_n = b.get("calls", 0)
            tok_in = fmt_tokens(b.get("input", 0))
            b_cost = fmt_cost(b.get("cost", 0))
            b_bar = bar(b.get("cost", 0), max_cost)
            # Subagent labels already include call count; only append for main session blocks
            if b.get("is_subagent"):
                display_label = label
            else:
                display_label = f"{label} ({calls_n}c)"
            lines.append(f"| {display_label} | {tok_in} | {b_cost} | {b_bar} |")
        lines.append("")

    # Top issues
    if issues:
        lines += ["**TOP ISSUES**", ""]
        for i, issue in enumerate(issues, 1):
            sev = issue.get("severity", "info")
            icon = "🔴" if sev == "critical" else ("⚠️" if sev == "warning" else "ℹ️")
            sev_label = sev.upper()
            itype = issue.get("type", "unknown")
            if itype == "high_ratio":
                val = issue.get("value", "?")
                thr = issue.get("threshold", "?")
                desc = f"Input:output ratio {val}:1 (target <{thr}:1)"
            elif itype == "rogue_subagent":
                c = issue.get("calls", "?")
                desc = f"Subagent ran {c} calls"
            elif itype == "context_explosion":
                pct = issue.get("pct", "?")
                at = issue.get("at_call", "?")
                desc = f"Context jumped {pct}% at call {at}"
            elif itype == "no_cache":
                desc = "No prompt cache hits"
            else:
                desc = itype
            lines.append(f"{i}. {icon} **[{sev_label}]** {desc}")
        lines.append("")

    # Per-call breakdown
    if breakdown:
        per_call = session.get("per_call", [])
        bd = render_call_breakdown(per_call)
        if bd:
            lines.append(bd)

    # Model breakdown
    if models:
        lines.append(render_model_breakdown(session))

    # Savings comparison
    if savings:
        lines += [
            "**IF YOU'D USED A CHEAPER MODEL**",
            "",
            "| Model | Est. cost | Saving | Best for |",
            "|---|---|---|---|",
        ]
        for s in savings[:4]:
            m = s.get("model", "")
            ec = fmt_cost(s.get("est_cost", 0))
            sv = s.get("saving_pct", 0)
            note = s.get("note", "")
            lines.append(f"| {m} | {ec} | -{sv}% | {note} |")
        lines.append("")

    return "\n".join(lines)


# ──────────────────────────────────────────────────────────────────────────────
# Multi-session dashboard (today / 24h / week)
# ──────────────────────────────────────────────────────────────────────────────

def render_multi_session(data: dict) -> str:
    mode = data.get("mode", "today")
    mode_label = {"today": "Today", "24h": "Last 24h", "week": "Last 7 Days"}.get(mode, mode)
    period = data.get("period", "")
    sessions = [s for s in data.get("sessions", []) if s.get("api_calls", 0) > 0]
    totals = data.get("totals", {})
    top_issues = data.get("top_issues", [])

    lines = []
    lines.append(f"**TOKEN ANALYSIS** · {mode_label} · {period}")
    lines.append("")

    if not sessions:
        lines.append("_No sessions with API calls found for this period._")
        return "\n".join(lines)

    # Session table
    lines += [
        "| Session | Start | Dur | In/Out | Calls | Cost | Ratio | Health | Model | Alt | Alt Cost | Save | Reason |",
        "|---|---|---|---|---|---|---|---|---|---|---|---|---|",
    ]

    for s in sessions:
        sid = s.get("id", "?")[:8]
        start = s.get("start_local", "")
        dur = f"{s.get('duration_min', 0)}m"
        tok_in = fmt_tokens(s.get("input_tokens", 0))
        tok_out = fmt_tokens(s.get("output_tokens", 0))
        in_out = f"{tok_in}/{tok_out}"
        api = s.get("api_calls", 0)
        sa = s.get("subagent_calls", 0)
        calls_str = f"{api}+{sa}"
        cost = fmt_cost(s.get("est_cost_usd", 0.0))
        ratio = s.get("ratio", 0)
        h = session_health_icon(sid, top_issues)
        model = short_model(s.get("model", ""))
        rec = s.get("recommendation", {})
        alt = rec.get("model", "")
        alt_cost = fmt_cost(rec.get("est_cost", 0.0))
        save = f"-{rec.get('saving_pct', 0)}%"
        reason = truncate_reason(rec.get("reason", ""))
        lines.append(
            f"| {sid} | {start} | {dur} | {in_out} | {calls_str} | "
            f"{cost} | {ratio}:1 | {h} | {model} | {alt} | {alt_cost} | {save} | {reason} |"
        )

    # Totals row
    t_dur = f"**{totals.get('duration_min', 0)}m**"
    t_in = fmt_tokens(totals.get("input_tokens", 0))
    t_out = fmt_tokens(totals.get("output_tokens", 0))
    t_calls = totals.get("api_calls", 0)
    t_cost = fmt_cost(totals.get("est_cost_usd", 0.0))
    t_alt = fmt_cost(totals.get("alt_cost_usd", 0.0))
    lines.append(
        f"| **Total** | | {t_dur} | **{t_in}/{t_out}** | **{t_calls}** | "
        f"**{t_cost}** | | | | | **{t_alt}** | | |"
    )
    lines.append("")

    # Worst session narrative
    if sessions:
        worst = max(sessions, key=lambda s: s.get("est_cost_usd", 0))
        lines += [generate_narrative(worst), ""]

    # Issues
    issues_section = format_issues_section(top_issues)
    if issues_section:
        lines += [issues_section]

    return "\n".join(lines)


