def render_footer(top_issues: list) -> str:
    issue_types = list({i.get("type") for i in top_issues if i.get("type")})
    lines = [
        "---",
        "**Next steps:** Ask me anything about these numbers — I can drill into any session, explain a pattern, or compare two sessions.",
    ]
    if issue_types:
        lines.append(
            f"To write token-efficiency guidelines to your CLAUDE.md: re-run with `--write-guidelines`"
        )
    lines.append("To save a full Markdown report: re-run with `--report`")
    return "\n".join(lines)


# ──────────────────────────────────────────────────────────────────────────────
# Full report (--report)
# ──────────────────────────────────────────────────────────────────────────────

def render_full_report(data: dict) -> str:
    """Full report Markdown — superset of the inline dashboard."""
    mode = data.get("mode", "session")
    period = data.get("period", "")
    totals = data.get("totals", {})
    sessions = [s for s in data.get("sessions", []) if s.get("api_calls", 0) > 0]
    top_issues = data.get("top_issues", [])
    savings = data.get("savings_comparison", [])
    health = data.get("health", "ok")

    lines = [
        f"# Token Analyser Report",
        f"",
        f"**Period:** {period}  ",
        f"**Mode:** {mode}  ",
        f"**Health:** {health_icon(health)}  ",
        f"**Total cost:** {fmt_cost(totals.get('est_cost_usd', 0))}  ",
        f"**Total calls:** {totals.get('api_calls', 0)}  ",
        f"**Duration:** {totals.get('duration_min', 0)}m",
        "",
        "---",
        "",
    ]

    # Inline dashboard
    if mode == "session":
        lines.append(render_single_session(data))
    else:
        lines.append(render_multi_session(data))

    # Savings table (for reports, always include)
    if savings:
        lines += [
            "",
            "## Savings Comparison",
            "",
            "| Model | Est. cost | Saving | Best for |",
            "|---|---|---|---|",
        ]
        for s in savings:
            lines.append(
                f"| {s.get('model','')} | {fmt_cost(s.get('est_cost',0))} "
                f"| -{s.get('saving_pct',0)}% | {s.get('note','')} |"
            )

    # Self-heal recommendations
    if top_issues:
        issue_types = list({i.get("type") for i in top_issues})
        applicable = [t for t in issue_types if t in _GUIDELINES]
        if applicable:
            lines += [
                "",
                "## Self-Heal Recommendations",
                "",
                "Add the following sections to your `CLAUDE.md` to prevent these issues:",
                "",
            ]
            for t in applicable:
                lines.append(f"```markdown\n{_GUIDELINES[t].strip()}\n```")
                lines.append("")

    return "\n".join(lines)


# ──────────────────────────────────────────────────────────────────────────────
# Main
# ──────────────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="Token Analyser — formats Claude Code session token data as a Markdown dashboard."
    )
    mode_group = parser.add_mutually_exclusive_group()
    mode_group.add_argument("--today", action="store_true", help="Sessions from today (calendar day)")
    mode_group.add_argument("--24h", dest="h24", action="store_true", help="Sessions from last 24 hours")
    mode_group.add_argument("--week", action="store_true", help="Sessions from last 7 days")
    mode_group.add_argument("--session", metavar="UUID", help="Specific session by UUID")

    parser.add_argument(
        "--project-path",
        default=os.environ.get("PWD", os.getcwd()),
        help="Project directory (default: $PWD)",
    )
    parser.add_argument(
        "--report",
        nargs="?",
        const="auto",
        metavar="OUTPUT_PATH",
        help="Save full report to file (default: .claude/reports/token-analyser-TIMESTAMP.md)",
    )
    parser.add_argument(
        "--write-guidelines",
        action="store_true",
        help="Append token-efficiency guidelines to <project-path>/CLAUDE.md",
    )
    parser.add_argument("--json", action="store_true", help="Output raw JSON from parse-logs.py")
    parser.add_argument("--breakdown", action="store_true", help="Show per-call token breakdown (raw input, cache write, cache read, output)")
    parser.add_argument("--models", action="store_true", help="Show per-model usage breakdown — answers 'did agents use different models?'")
    args = parser.parse_args()

    # Build parse-logs.py command
    cmd = [sys.executable, str(_PARSE_LOGS), "--project-path", args.project_path]
    if args.h24:
        cmd.append("--24h")
    elif args.today:
        cmd.append("--today")
    elif args.week:
        cmd.append("--week")
    elif args.session:
        cmd.extend(["--session", args.session])
    else:
        # Default: current session via $CLAUDE_SESSION_ID
        session_id = os.environ.get("CLAUDE_SESSION_ID")
        if session_id:
            cmd.extend(["--session", session_id])

    # Run parse-logs.py
    try:
        result = subprocess.run(cmd, capture_output=True, text=True)
    except FileNotFoundError:
        print(f"ERROR: parse-logs.py not found at {_PARSE_LOGS}", file=sys.stderr)
        sys.exit(1)

    if result.returncode != 0:
        print(result.stderr, file=sys.stderr)
        sys.exit(result.returncode)

    if result.stderr:
        print(result.stderr, file=sys.stderr)

    # JSON passthrough
    if args.json:
        print(result.stdout)
        return

    # Parse JSON
    try:
        data = json.loads(result.stdout)
    except json.JSONDecodeError as e:
        print(f"ERROR: failed to parse parse-logs.py output: {e}", file=sys.stderr)
        print(result.stdout, file=sys.stderr)
        sys.exit(1)

    # Write guidelines
    if args.write_guidelines:
        issue_types = list({i.get("type") for i in data.get("top_issues", [])})
        msg = write_guidelines(args.project_path, issue_types)
        print(f"[token-analyser] {msg}", file=sys.stderr)

    # Render output
    mode = data.get("mode", "session")
    if mode == "session":
        body = render_single_session(data, breakdown=args.breakdown, models=args.models)
    else:
        body = render_multi_session(data)

    footer = render_footer(data.get("top_issues", []))
    output = body.rstrip() + "\n\n" + footer

    # Report generation
    if args.report is not None:
        if args.report == "auto":
            ts = datetime.now().strftime("%Y-%m-%d-%H-%M")
            report_path = Path(args.project_path) / ".claude" / "reports" / f"token-analyser-{ts}.md"
        else:
            report_path = Path(args.report)

        report_path.parent.mkdir(parents=True, exist_ok=True)
        full_report = render_full_report(data)
        report_path.write_text(full_report)
        print(f"[token-analyser] Report saved to {report_path}", file=sys.stderr)

        # Open on macOS
        import platform
        if platform.system() == "Darwin":
            subprocess.run(["open", str(report_path)], check=False)

    print(output)


if __name__ == "__main__":
    main()
